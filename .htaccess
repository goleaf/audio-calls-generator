<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Canonical shared-hosting domain for the production subdomain.
    RewriteCond %{HTTP_HOST} !^audio-calls-generator\.prus\.dev$ [NC]
    RewriteRule ^ https://audio-calls-generator.prus.dev%{REQUEST_URI} [L,R=301]

    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
    RewriteRule ^ https://audio-calls-generator.prus.dev%{REQUEST_URI} [L,R=301]

    # Keep private Laravel application directories out of the document root.
    RewriteRule ^(?:app|bootstrap|config|database|node_modules|public|resources|routes|tests|vendor)(?:/|$) - [F,L]
    RewriteRule ^(?:artisan|composer\.(?:json|lock)|package(?:-lock)?\.json|phpunit\.xml|vite\.config\.js|postcss\.config\.cjs|AGENTS\.md|CLAUDE\.md|GEMINI\.md|README\.md|opencode\.json|boost\.json)$ - [F,L]
    RewriteRule (^|/)\.(?!well-known(?:/|$)) - [F,L]

    # Serve public storage files from storage/app/public without exposing private storage.
    RewriteRule ^storage/audio/(.+)$ index.php [L,QSA]
    RewriteCond %{THE_REQUEST} \s/+storage/app/public/ [NC]
    RewriteRule ^storage/app/public/ - [F,L]
    RewriteRule ^storage/(.*)$ storage/app/public/$1 [L]
    RewriteRule ^storage/ - [F,L]

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
